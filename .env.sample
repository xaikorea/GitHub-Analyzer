# ============================================================
# .env.sample — copy to .env (or .env.gemini / .env.openai) and fill in.
# .env* files are gitignored except this sample.
# ============================================================

# --- LLM provider selection ---
# One of: GEMINI, OPENAI  (or any OpenAI-compatible provider name, see below)
LLM_PROVIDER=GEMINI

# --- Gemini (Google) ---
# Use EITHER an API key (AI Studio) ...
GEMINI_API_KEY=<GEMINI_API_KEY>
GEMINI_MODEL=gemini-2.5-flash
# ... OR Vertex AI (project-based). If GEMINI_PROJECT_ID is set it takes precedence.
# GEMINI_PROJECT_ID=<GCP_PROJECT_ID>
# GEMINI_LOCATION=us-central1

# --- OpenAI (used for chat AND for RAG embeddings) ---
OPENAI_API_KEY=<OPENAI_API_KEY>
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com
# Embedding model used by db_store.py when create_embeddings=True
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Any other OpenAI-compatible provider (Ollama, XAI, OpenRouter, ...) ---
# Set LLM_PROVIDER to the provider name and define these three:
# <PROVIDER>_MODEL / <PROVIDER>_BASE_URL / <PROVIDER>_API_KEY
# OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
# OPENROUTER_MODEL=<OPENROUTER_MODEL>
# OPENROUTER_BASE_URL=https://openrouter.ai/api

# --- App login (team-only access) ---
# When both are set, the Streamlit app shows a login screen on entry.
# Leave both empty to disable the gate (open access, with a warning).
APP_USERNAME=<APP_USERNAME>
APP_PASSWORD=<APP_PASSWORD>

# --- GitHub (repo crawling) ---
# Optional for public repos but strongly recommended to avoid rate limits;
# required for private repos.
GITHUB_TOKEN=<GITHUB_TOKEN>

# --- Database (Streamlit app: Library / RAG / Ontology) ---
# Postgres with the pgvector extension. Initialize with: psql "$DATABASE_URL" -f schema.sql
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Misc (optional) ---
# LOG_DIR=logs
# Create OpenAI embeddings when saving a tutorial -> enables semantic RAG
# search (needs OPENAI_API_KEY). Off by default; set to 1/true/yes/on.
# RAG_CREATE_EMBEDDINGS=0
# Char budget for the single IdentifyAbstractions prompt. When a repo's
# total context exceeds this, the largest files are dropped (and logged).
# <=0 means unlimited. Default 900000.
# MAX_ABSTRACTION_CONTEXT_CHARS=900000
